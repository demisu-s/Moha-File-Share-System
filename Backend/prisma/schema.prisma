// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ CORE MODELS ============

model Plant {
  id            String    @id @default(cuid())
  name          String    @unique
  code          String    @unique
  location      String
  address       String?
  phone         String?
  email         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  departments   Department[]
  users         User[]
  files         File[]
  fileShares    FileShare[] @relation("PlantShares")
  
  // Metadata
  createdBy     String?
  settings      Json?
}

model Department {
  id            String    @id @default(cuid())
  name          String
  code          String    @unique
  description   String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  plantId       String
  plant         Plant     @relation(fields: [plantId], references: [id])
  users         User[]
  files         File[]
  fileShares    FileShare[] @relation("DeptShares")
  
  // Metadata
  createdBy     String?
  settings      Json?
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  fullName      String
  employeeId    String    @unique
  phone         String?
  profileImage  String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations - Hierarchical
  plantId       String?
  plant         Plant?    @relation(fields: [plantId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  
  // Role & Permissions
  role          Role      @default(EMPLOYEE)
  permissions   Permission[]
  
  // File Relations
  uploadedFiles File[]    @relation("UploadedFiles")
  sharedFiles   FileShare[]
  notifications Notification[]
  auditLogs     AuditLog[]
  fileAccessLogs FileAccessLog[]
  
  // Created by
  createdBy     String?
}

model File {
  id            String    @id @default(cuid())
  fileName      String
  originalName  String
  fileSize      Int
  fileType      String
  mimeType      String
  filePath      String
  fileHash      String?
  version       Int       @default(1)
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations - Hierarchical
  plantId       String?
  plant         Plant?    @relation(fields: [plantId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  
  uploadedById  String
  uploadedBy    User      @relation("UploadedFiles", fields: [uploadedById], references: [id])
  
  shares        FileShare[]
  accessLogs    FileAccessLog[]
  
  // Metadata - REMOVED String[] because MySQL doesn't support arrays
  // tags          String[]  // REMOVED - MySQL doesn't support arrays
  description   String?
  category      FileCategory @default(OTHER)
}

model FileShare {
  id            String    @id @default(cuid())
  
  fileId        String
  file          File      @relation(fields: [fileId], references: [id])
  
  sharedBy      String
  sharedAt      DateTime  @default(now())
  
  // Who gets access
  sharedWithUserId  String?
  sharedWithUser    User?     @relation(fields: [sharedWithUserId], references: [id])
  sharedWithPlantId String?
  sharedWithPlant   Plant?    @relation("PlantShares", fields: [sharedWithPlantId], references: [id])
  sharedWithDeptId  String?
  sharedWithDept    Department? @relation("DeptShares", fields: [sharedWithDeptId], references: [id])
  sharedWithAll     Boolean   @default(false)
  
  permission    PermissionLevel @default(VIEW)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model FileAccessLog {
  id            String    @id @default(cuid())
  fileId        String
  file          File      @relation(fields: [fileId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  action        AccessAction
  ipAddress     String?
  userAgent     String?
  accessedAt    DateTime  @default(now())
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  title         String
  message       String
  type          NotificationType
  isRead        Boolean   @default(false)
  readAt        DateTime?
  link          String?
  createdAt     DateTime  @default(now())
}

model AuditLog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  action        String
  resourceType  ResourceType
  resourceId    String?
  details       Json
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())
}

// ============ ENUMS ============

enum Role {
  SUPER_ADMIN
  PLANT_ADMIN
  DEPARTMENT_HEAD
  EMPLOYEE
  VIEWER
}

enum PermissionLevel {
  VIEW
  EDIT
  DELETE
  SHARE
  FULL_CONTROL
}

enum FileCategory {
  DOCUMENT
  SPREADSHEET
  PRESENTATION
  PDF
  IMAGE
  VIDEO
  OTHER
}

enum NotificationType {
  FILE_SHARED
  FILE_UPLOADED
  FILE_DELETED
  PERMISSION_CHANGE
  PLANT_CREATED
  DEPARTMENT_CREATED
  USER_CREATED
  SYSTEM_UPDATE
}

enum AccessAction {
  VIEW
  DOWNLOAD
  EDIT
  DELETE
  SHARE
}

enum ResourceType {
  PLANT
  DEPARTMENT
  USER
  FILE
  SHARE
  PERMISSION
}

// ============ PERMISSION SYSTEM ============

model Permission {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  resourceType  ResourceType
  resourceId    String?
  action        String
  allowed       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  
  @@unique([userId, resourceType, resourceId, action])
}